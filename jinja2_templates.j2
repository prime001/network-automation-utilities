#!/usr/bin/env python3
"""
007_jinja2_config_renderer.py - Network Device Configuration Template Renderer

Generates vendor-specific device configurations from structured data using
Jinja2 templates. Supports Cisco IOS and Juniper JunOS with built-in example
device data — no external APIs required.

Usage:
    python 007_jinja2_config_renderer.py                  # renders first device (demo)
    python 007_jinja2_config_renderer.py --all            # render all example devices
    python 007_jinja2_config_renderer.py --device core-sw-01
    python 007_jinja2_config_renderer.py --vendor juniper
    python 007_jinja2_config_renderer.py --list-devices
"""

import argparse
import sys
from textwrap import dedent

try:
    from jinja2 import Environment, BaseLoader
    import yaml
except ImportError:
    sys.exit("Install dependencies: pip install jinja2 pyyaml")


DEVICE_DATA_YAML = """
devices:
  - name: core-sw-01
    vendor: cisco
    hostname: CORE-SW-01
    domain: corp.example.com
    interfaces:
      - name: GigabitEthernet0/0
        ip: 10.0.0.1
        mask: 255.255.255.0
        description: Uplink to Distribution
      - name: GigabitEthernet0/1
        ip: 192.168.10.1
        mask: 255.255.255.0
        description: LAN Segment A
    vlans:
      - id: 10
        name: MANAGEMENT
      - id: 20
        name: SERVERS
      - id: 30
        name: USERS
    ntp_servers: [10.0.0.254, 10.0.0.253]
    snmp_community: readonly
    logging_host: 10.0.0.100
    dns_servers: [8.8.8.8, 8.8.4.4]

  - name: edge-rtr-01
    vendor: juniper
    hostname: EDGE-RTR-01
    domain: corp.example.com
    interfaces:
      - name: ge-0/0/0
        ip: 203.0.113.1
        prefix_len: 30
        description: WAN Uplink
      - name: ge-0/0/1
        ip: 10.0.0.254
        prefix_len: 24
        description: Core LAN
    ntp_servers: [10.0.0.1]
    snmp_community: monitoring
    logging_host: 10.0.0.100
    static_routes:
      - prefix: 0.0.0.0/0
        next_hop: 203.0.113.2
"""

TEMPLATES = {
    "cisco": dedent("""\
        ! Generated by 007_jinja2_config_renderer.py
        hostname {{ hostname }}
        ip domain-name {{ domain }}
        !
        {% for dns in dns_servers | default([]) -%}
        ip name-server {{ dns }}
        {% endfor -%}
        !
        {% for iface in interfaces -%}
        interface {{ iface.name }}
         description {{ iface.description }}
         ip address {{ iface.ip }} {{ iface.mask }}
         no shutdown
        !
        {% endfor -%}
        {% for vlan in vlans | default([]) -%}
        vlan {{ vlan.id }}
         name {{ vlan.name }}
        !
        {% endfor -%}
        {% for ntp in ntp_servers | default([]) -%}
        ntp server {{ ntp }}
        {% endfor -%}
        !
        snmp-server community {{ snmp_community }} RO
        logging host {{ logging_host }}
        logging trap informational
        !
        end
    """),

    "juniper": dedent("""\
        /* Generated by 007_jinja2_config_renderer.py */
        system {
            host-name {{ hostname }};
            domain-name {{ domain }};
            syslog { host {{ logging_host }} { any any; } }
            ntp {
        {% for ntp in ntp_servers | default([]) -%}
                server {{ ntp }};
        {% endfor -%}
            }
        }
        interfaces {
        {% for iface in interfaces -%}
            {{ iface.name }} {
                unit 0 {
                    description "{{ iface.description }}";
                    family inet { address {{ iface.ip }}/{{ iface.prefix_len }}; }
                }
            }
        {% endfor -%}
        }
        routing-options {
        {% for route in static_routes | default([]) -%}
            static { route {{ route.prefix }} next-hop {{ route.next_hop }}; }
        {% endfor -%}
        }
        snmp {
            community {{ snmp_community }} { authorization read-only; }
        }
    """),
}


def render_config(device: dict) -> str:
    vendor = device.get("vendor", "").lower()
    template_str = TEMPLATES.get(vendor)
    if not template_str:
        raise ValueError(f"No template for vendor '{vendor}'. Supported: {list(TEMPLATES)}")
    env = Environment(loader=BaseLoader(), trim_blocks=True, lstrip_blocks=True)
    return env.from_string(template_str).render(**device)


def main():
    parser = argparse.ArgumentParser(description="Render network device configs via Jinja2 templates")
    parser.add_argument("--device", help="Render config for a specific device name")
    parser.add_argument("--vendor", help="Filter by vendor (cisco, juniper)")
    parser.add_argument("--all", action="store_true", help="Render all devices")
    parser.add_argument("--list-devices", action="store_true", help="List available devices")
    args = parser.parse_args()

    devices = yaml.safe_load(DEVICE_DATA_YAML).get("devices", [])

    if args.list_devices:
        print(f"{'Name':<20} {'Vendor':<12} Hostname")
        print("-" * 46)
        for d in devices:
            print(f"{d['name']:<20} {d['vendor']:<12} {d['hostname']}")
        return

    if args.device:
        targets = [d for d in devices if d["name"] == args.device]
        if not targets:
            sys.exit(f"Device '{args.device}' not found. Use --list-devices to see options.")
    elif args.vendor:
        targets = [d for d in devices if d["vendor"].lower() == args.vendor.lower()]
    elif args.all:
        targets = devices
    else:
        targets = devices[:1]
        print("# Tip: use --all, --device NAME, or --vendor VENDOR to select targets.\n")

    for device in targets:
        print(f"{'=' * 60}")
        print(f"# {device['name']}  ({device['vendor']})")
        print(f"{'=' * 60}")
        try:
            print(render_config(device))
        except ValueError as exc:
            print(f"ERROR: {exc}\n")


if __name__ == "__main__":
    main()